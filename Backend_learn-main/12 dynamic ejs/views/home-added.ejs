<%- include('partials/head') %>

<body class="bg-gray-100 min-h-screen">

  <!-- Navbar -->
  <%- include('partials/navbar') %>

  <!-- Success Section -->
  <section class="flex items-center justify-center min-h-[85vh] px-6">

    <div class="bg-white shadow-2xl rounded-3xl p-12 max-w-2xl w-full text-center">

      <!-- Success Icon -->
      <div class="flex justify-center mb-6">

        <div class="bg-green-100 p-6 rounded-full">
          <span class="text-5xl">
            ✅
          </span>
        </div>

      </div>

      <!-- Heading -->
      <h1 class="text-5xl font-bold text-gray-800 mb-4">
        Home Added Successfully!
      </h1>

      <!-- Description -->
      <p class="text-gray-600 text-lg leading-relaxed mb-10">
        Thank you for submitting your property details.
        Your home is now registered on Airbnb.
      </p>

      <!-- Buttons -->
      <div class="flex flex-col sm:flex-row gap-5 justify-center">

        <a href="/user/"
          class="bg-rose-500 hover:bg-rose-600 text-white px-8 py-4 rounded-xl text-lg font-semibold shadow-lg transition duration-300">
          Go To Home
        </a>

        <a href="/host/add-home"
          class="border-2 border-gray-300 hover:border-rose-500 hover:text-rose-500 px-8 py-4 rounded-xl text-lg font-semibold transition duration-300">
          Add Another Home
        </a>

      </div>

    </div>

  </section>

</body>
</html>