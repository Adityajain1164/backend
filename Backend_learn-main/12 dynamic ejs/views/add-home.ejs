<%- include('partials/head') %>

<body class="bg-gray-100 min-h-screen">

  <!-- Navbar -->
  <%- include('partials/navbar') %>

  <!-- Form Section -->
  <section class="flex items-center justify-center py-16 px-6">

    <div class="bg-white shadow-2xl rounded-3xl p-10 w-full max-w-xl">

      <h1 class="text-4xl font-bold text-center text-gray-800 mb-3">
        Register Your Home
      </h1>

      <p class="text-center text-gray-500 mb-8">
        Add your beautiful property and start hosting guests.
      </p>

      <form action="/host/add-home" method="POST" class="space-y-6">

        <!-- House Name -->
        <div>
          <label class="block text-gray-700 font-semibold mb-2">
            House Name
          </label>

          <input
            type="text"
            name="houseName"
            placeholder="Enter house name"
            class="w-full border border-gray-300 rounded-xl px-5 py-4 focus:outline-none focus:ring-2 focus:ring-rose-400 focus:border-rose-400 transition duration-300"
          />
        </div>

        <!-- Location -->
        <div>
          <label class="block text-gray-700 font-semibold mb-2">
            Location
          </label>

          <input
            type="text"
            name="location"
            placeholder="Enter location"
            class="w-full border border-gray-300 rounded-xl px-5 py-4 focus:outline-none focus:ring-2 focus:ring-rose-400 focus:border-rose-400 transition duration-300"
          />
        </div>

        <!-- Price -->
        <div>
          <label class="block text-gray-700 font-semibold mb-2">
            Price Per Night
          </label>

          <input
            type="number"
            name="price"
            placeholder="₹ Enter price"
            class="w-full border border-gray-300 rounded-xl px-5 py-4 focus:outline-none focus:ring-2 focus:ring-rose-400 focus:border-rose-400 transition duration-300"
          />
        </div>

        <!-- Submit Button -->
        <button
          type="submit"
          class="w-full bg-rose-500 hover:bg-rose-600 text-white py-4 rounded-xl text-lg font-semibold shadow-lg transition duration-300"
        >
          Add Home
        </button>

      </form>

    </div>

  </section>

</body>
</html>